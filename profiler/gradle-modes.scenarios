baseline {
    tasks = ["classes"]
    cleanup-tasks = ["clean"]
    gradle-args = [
        "--rerun-tasks",
        "--parallel",
        "--no-build-cache",
        "--no-configuration-cache",
        "--no-configure-on-demand"
    ]
}

build-cache {
    tasks = ["classes"]
    cleanup-tasks = ["clean"]
    gradle-args = [
        "--parallel",
        "--build-cache",
        "--no-configuration-cache",
        "--no-configure-on-demand"
    ]
}

build-cache-configuration-cache {
    tasks = ["classes"]
    cleanup-tasks = ["clean"]
    gradle-args = [
        "--parallel",
        "--build-cache",
        "--configuration-cache",
        "--no-configure-on-demand"
    ]
}

all-three {
    tasks = ["classes"]
    cleanup-tasks = ["clean"]
    gradle-args = [
        "--parallel",
        "--build-cache",
        "--configuration-cache",
        "--configure-on-demand"
    ]
}
